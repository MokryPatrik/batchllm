# BatchLLM API key (for authenticating to the web server)
BATCHLLM_API_KEY=changeme

# Default LLM model (LiteLLM format)
BATCHLLM_DEFAULT_MODEL=moonshot/moonshot-v1-8k

# Default concurrency (parallel requests)
BATCHLLM_DEFAULT_CONCURRENCY=10

# Default max retries per request
BATCHLLM_DEFAULT_MAX_RETRIES=3

# Default temperature
BATCHLLM_DEFAULT_TEMPERATURE=0.7

# Default max tokens
BATCHLLM_DEFAULT_MAX_TOKENS=1024

# Data directory for JSONL result files
BATCHLLM_DATA_DIR=./data

# --- LLM Provider API Keys ---
# Set the key for whichever provider you're using

# Moonshot AI
MOONSHOT_API_KEY=your-moonshot-api-key

# OpenAI (optional)
# OPENAI_API_KEY=your-openai-key

# Anthropic (optional)
# ANTHROPIC_API_KEY=your-anthropic-key

# Google Gemini (optional)
# GEMINI_API_KEY=your-gemini-key
